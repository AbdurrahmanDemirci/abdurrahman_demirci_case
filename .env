# ============================================================
# Environment Configuration
# All variables are required — missing var returns None and crashes.
# ============================================================

# ── UI Test Settings ─────────────────────────────────────────
BASE_URL=https://insiderone.com
BROWSER=chrome                  # chrome | firefox
HEADLESS=false                  # true | false
EXPLICIT_WAIT=30                # seconds

# ── API Test Settings ────────────────────────────────────────
API_BASE_URL=https://petstore.swagger.io/v2
API_TIMEOUT=10                  # seconds

# ── Load Test Settings ───────────────────────────────────────
LOAD_TEST_ENV=production        # production | staging | local
MIN_RESPONSE_BODY_SIZE=500      # minimum response body size (bytes)
P95_THRESHOLD_MS=3000           # P95 response time warning threshold (ms)
THINK_TIME_MIN=2                # min wait between tasks (seconds)
THINK_TIME_MAX=5                # max wait between tasks (seconds)
